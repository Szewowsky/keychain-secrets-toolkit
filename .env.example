# .env.example — szablon dla kluczy API AI
#
# Ten plik jest dodany do gita. Prawdziwy plik .env (z rzeczywistymi wartościami) NIE JEST.
# Rzeczywiste wartości znajdują się w macOS Keychain. Uruchom `python3 scripts/setup_keyring.py`,
# aby wykonać migrację, lub dodaj klucze bezpośrednio za pomocą `security add-generic-password`.
#
# Wszystkie placeholdery są celowe — nigdy nie umieszczaj tu prawdziwych kluczy.

OPENAI_API_KEY=STORED_IN_KEYRING
ANTHROPIC_API_KEY=STORED_IN_KEYRING
OPENROUTER_API_KEY=STORED_IN_KEYRING
GEMINI_API_KEY=STORED_IN_KEYRING
