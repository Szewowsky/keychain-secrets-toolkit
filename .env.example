# .env.example — template for AI API keys
#
# This file is committed to git. The real .env (with actual values) is NOT.
# Real values live in macOS Keychain. Run `python3 scripts/setup_keyring.py`
# to migrate, or add keys directly with `security add-generic-password`.
#
# All placeholders are intentional — never put real keys here.

OPENAI_API_KEY=STORED_IN_KEYRING
ANTHROPIC_API_KEY=STORED_IN_KEYRING
OPENROUTER_API_KEY=STORED_IN_KEYRING
GEMINI_API_KEY=STORED_IN_KEYRING
