# .env.example — TEMPLATE dla kluczy API AI
#
# ⚠️  TO SĄ PLACEHOLDERY. Wartość "STORED_IN_KEYRING" oznacza:
#     "prawdziwa wartość jest w macOS Keychain, nie tutaj".
#     NIGDY nie wpisuj prawdziwego klucza do tego pliku — on jest commitowany do gita!
#
# 📋 JAK UŻYWAĆ:
#
#   Ścieżka A — interactive (zalecana, najbezpieczniejsza):
#     python3 scripts/setup_keyring.py --interactive
#       → wpisujesz klucze w prompcie, idą prosto do Keychain
#       → plik .env w ogóle nie jest potrzebny
#
#   Ścieżka B — migracja z istniejącego .env (jeśli masz już klucze gdzieś):
#     cp .env.example .env             # tworzysz LOKALNY .env z tego templatu
#     # edytujesz .env, wpisujesz PRAWDZIWE klucze (tymczasowo, tylko do migracji)
#     python3 scripts/setup_keyring.py # migracja: wartości idą do Keychain
#     # po migracji .env jest automatycznie nadpisany placeholderami STORED_IN_KEYRING
#
#   Ścieżka C — bezpośrednio CLI security (bez .env):
#     security add-generic-password -U -a OPENAI_API_KEY -s my-secrets -w 'sk-proj-XXX'
#
# ❌ NIE rób:
#   - NIE wpisuj prawdziwych kluczy do TEGO pliku (.env.example) — on jest w repo!
#   - NIE commituj swojego lokalnego .env (chroni go .gitignore — ale uważaj na `git add -f`)
#
# ✅ Format każdej linii:
#     NAZWA_KLUCZA=STORED_IN_KEYRING
#
# Patrz README.md sekcja "Dlaczego dwa pliki: .env.example vs .env" oraz docs/security-first.md.

OPENAI_API_KEY=STORED_IN_KEYRING
ANTHROPIC_API_KEY=STORED_IN_KEYRING
OPENROUTER_API_KEY=STORED_IN_KEYRING
GEMINI_API_KEY=STORED_IN_KEYRING
